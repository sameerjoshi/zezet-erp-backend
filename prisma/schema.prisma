// Zezet ERP — Prisma schema (Phase 0–1 baseline)
// Mirrors SPEC_Trial_Phase0-1.md §4. The Trip is the universal record.
// Conventions: soft-delete via status/ deletedAt (preserve context); USD only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Identity & access ----------

enum UserStatus {
  active
  disabled
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String?    @unique
  phone        String?
  passwordHash String
  locale       String     @default("en") // en | es
  status       UserStatus @default(active)
  roles        UserRole[]
  worker       Worker? // optional link (future driver login)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum RoleKey {
  admin
  finance
  ops_manager
  ops_staff
  driver
  investor
}

model Role {
  id    String     @id @default(cuid())
  key   RoleKey    @unique
  name  String
  users UserRole[]
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  @@id([userId, roleId])
}

// ---------- Workforce ----------

enum WorkerType {
  employee
  contractor
}

model Worker {
  id            String     @id @default(cuid())
  fullName      String
  type          WorkerType @default(contractor)
  canDrive      Boolean    @default(true)
  canHelp       Boolean    @default(true)
  status        UserStatus @default(active)
  user          User?      @relation(fields: [userId], references: [id])
  userId        String?    @unique
  tripsAsDriver Trip[]     @relation("DriverTrips")
  tripsAsHelper Trip[]     @relation("HelperTrips")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ---------- Fleet ----------

enum TruckStatus {
  active
  inactive
}

model Truck {
  id            String          @id @default(cuid())
  code          String          @unique // e.g. "Camión 7"
  plate         String?
  year          Int?
  sizeFt        Int?
  purchaseDate  DateTime?
  purchasePrice Decimal?        @db.Decimal(12, 2)
  odometerStart Int?
  status        TruckStatus     @default(active)
  logs          DailyTruckLog[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// ---------- Clients & pricing ----------

model Client {
  id                String      @id @default(cuid())
  name              String
  code              String?     @unique
  billingFrequency  String? // free-text hint; periods are irregular/client-driven
  status            UserStatus  @default(active)
  rateCards         RateCard[]
  trips             Trip[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model RateCard {
  id        String   @id @default(cuid())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  name      String
  status    UserStatus @default(active)
  rates     Rate[]
  createdAt DateTime @default(now())
}

// A rate prepopulates a trip's charge + driver/helper pay. All editable per trip.
model Rate {
  id            String    @id @default(cuid())
  rateCard      RateCard  @relation(fields: [rateCardId], references: [id], onDelete: Cascade)
  rateCardId    String
  label         String? // route / service label
  clientPrice   Decimal   @db.Decimal(12, 2)
  driverPay     Decimal   @db.Decimal(12, 2)
  helperPay     Decimal   @db.Decimal(12, 2)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  trips         Trip[]
}

// ---------- Operations (the universal record) ----------

enum LogStatus {
  draft
  confirmed
}

model DailyTruckLog {
  id            String    @id @default(cuid())
  date          DateTime  @db.Date
  truck         Truck     @relation(fields: [truckId], references: [id])
  truckId       String
  fuelCost      Decimal?  @db.Decimal(12, 2)
  odometerStart Int?
  odometerEnd   Int?
  notes         String?
  status        LogStatus @default(draft)
  enteredById   String?
  trips         Trip[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([date, truckId])
}

model Trip {
  id             String        @id @default(cuid())
  dailyLog       DailyTruckLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dailyLogId     String
  seq            Int           @default(1)
  client         Client        @relation(fields: [clientId], references: [id])
  clientId       String
  routeLabel     String?
  billAmount     Decimal       @db.Decimal(12, 2)
  driver         Worker        @relation("DriverTrips", fields: [driverWorkerId], references: [id])
  driverWorkerId String
  helper         Worker?       @relation("HelperTrips", fields: [helperWorkerId], references: [id])
  helperWorkerId String?
  driverPay      Decimal       @db.Decimal(12, 2)
  helperPay      Decimal       @default(0) @db.Decimal(12, 2)
  rate           Rate?         @relation(fields: [rateId], references: [id])
  rateId         String?
  createdById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// ---------- Audit ----------

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entity      String
  entityId    String
  action      String // create | update | delete
  before      Json?
  after       Json?
  at          DateTime @default(now())

  @@index([entity, entityId])
}
