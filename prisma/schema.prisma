// Zezet ERP — Prisma schema (Phase 0–1 baseline)
// Mirrors SPEC_Trial_Phase0-1.md §4. The Trip is the universal record.
// Conventions: soft-delete via status/ deletedAt (preserve context); USD only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Identity & access ----------

enum UserStatus {
  active
  disabled
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String?    @unique
  phone        String?
  passwordHash String
  locale       String     @default("en") // en | es
  status       UserStatus @default(active)
  roles        UserRole[]
  worker       Worker? // optional link (future driver login)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum RoleKey {
  admin
  finance
  ops_manager
  ops_staff
  driver
  investor
}

model Role {
  id    String     @id @default(cuid())
  key   RoleKey    @unique
  name  String
  users UserRole[]
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  @@id([userId, roleId])
}

// ---------- Workforce ----------

enum WorkerType {
  employee
  contractor
}

model Worker {
  id            String     @id @default(cuid())
  fullName      String
  type          WorkerType @default(contractor)
  canDrive      Boolean    @default(true)
  canHelp       Boolean    @default(true)
  status        UserStatus @default(active)
  user          User?      @relation(fields: [userId], references: [id])
  userId        String?    @unique
  tripsAsDriver Trip[]     @relation("DriverTrips")
  tripsAsHelper Trip[]     @relation("HelperTrips")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ---------- Fleet ----------

enum TruckStatus {
  active
  inactive
}

model Truck {
  id            String          @id @default(cuid())
  code          String          @unique // e.g. "Camión 7"
  plate         String?
  year          Int?
  sizeFt        Int?
  purchaseDate  DateTime?
  // Date the truck is actually ready/legal to drive (paperwork + initial repairs
  // done). A truck only counts toward operational % from this date — a just-bought,
  // not-yet-drivable truck must not deflate the percentage.
  inServiceDate DateTime?       @db.Date
  purchasePrice Decimal?        @db.Decimal(12, 2)
  odometerStart Int?
  status        TruckStatus     @default(active)
  logs          DailyTruckLog[]
  costs         TruckCost[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// ---------- Clients & pricing ----------

model Client {
  id                String      @id @default(cuid())
  name              String
  code              String?     @unique
  billingFrequency  String? // free-text hint; periods are irregular/client-driven
  status            UserStatus  @default(active)
  rateCards         RateCard[]
  trips             Trip[]
  invoices          Invoice[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model RateCard {
  id        String   @id @default(cuid())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  name      String
  status    UserStatus @default(active)
  rates     Rate[]
  createdAt DateTime @default(now())
}

// A rate prepopulates a trip's charge + driver/helper pay. All editable per trip.
model Rate {
  id            String    @id @default(cuid())
  rateCard      RateCard  @relation(fields: [rateCardId], references: [id], onDelete: Cascade)
  rateCardId    String
  label         String? // route / service label
  clientPrice   Decimal   @db.Decimal(12, 2)
  driverPay     Decimal   @db.Decimal(12, 2)
  helperPay     Decimal   @db.Decimal(12, 2)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  trips         Trip[]
}

// ---------- Operations (the universal record) ----------

enum LogStatus {
  draft
  confirmed
}

// What the truck did that day (set by the field chief for every truck he visits,
// including idle ones). Distinct from LogStatus (the entry workflow): a day can be
// confirmed AND broken. Null = not recorded / not expected to run (e.g. a Sunday a
// truck legitimately rests) — these days are excluded from the operational %.
enum OperStatus {
  operating // drove (has trips/route/fuel/km)
  no_clients // idle for lack of work (sales)
  broken // down for repair (mechanics)
}

model DailyTruckLog {
  id            String    @id @default(cuid())
  date          DateTime  @db.Date
  truck         Truck     @relation(fields: [truckId], references: [id])
  truckId       String
  operStatus    OperStatus?
  fuelCost      Decimal?  @db.Decimal(12, 2)
  odometerStart Int?
  odometerEnd   Int?
  notes         String?
  status        LogStatus @default(draft)
  enteredById   String?
  trips         Trip[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([date, truckId])
}

model Trip {
  id             String        @id @default(cuid())
  dailyLog       DailyTruckLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dailyLogId     String
  seq            Int           @default(1)
  client         Client        @relation(fields: [clientId], references: [id])
  clientId       String
  routeLabel     String?
  billAmount     Decimal       @db.Decimal(12, 2)
  driver         Worker        @relation("DriverTrips", fields: [driverWorkerId], references: [id])
  driverWorkerId String
  helper         Worker?       @relation("HelperTrips", fields: [helperWorkerId], references: [id])
  helperWorkerId String?
  driverPay      Decimal       @db.Decimal(12, 2)
  helperPay      Decimal       @default(0) @db.Decimal(12, 2)
  rate           Rate?         @relation(fields: [rateId], references: [id])
  rateId         String?
  createdById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// ---------- Audit ----------

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entity      String
  entityId    String
  action      String // create | update | delete
  before      Json?
  after       Json?
  at          DateTime @default(now())

  @@index([entity, entityId])
}

// ---------- Billing / AR ----------
// Invoices over arbitrary, client-driven periods (ADR 0004). Lines are a frozen
// snapshot of the trips billed, so an issued invoice stays stable even if a trip
// is later edited or deleted.

enum InvoiceStatus {
  draft
  sent
  paid
  void
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique // INV-YYYY-NNNN
  client      Client        @relation(fields: [clientId], references: [id])
  clientId    String
  periodFrom  DateTime      @db.Date
  periodTo    DateTime      @db.Date
  status      InvoiceStatus @default(draft)
  issueDate   DateTime      @db.Date
  total       Decimal       @db.Decimal(12, 2)
  amountPaid  Decimal       @default(0) @db.Decimal(12, 2)
  paidAt      DateTime?
  notes       String?
  lines       InvoiceLine[]
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([clientId, status])
}

model InvoiceLine {
  id         String   @id @default(cuid())
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId  String
  tripId     String // plain reference, NOT an FK — the line is a frozen snapshot
  date       DateTime @db.Date
  truckCode  String
  routeLabel String?
  billAmount Decimal  @db.Decimal(12, 2)

  @@index([invoiceId])
  @@index([tripId])
}

// ---------- Payroll ----------
// Pay runs over periods with frozen per-trip pay lines (ADR 0005). Symmetric with
// Billing. tripId/workerId are plain references so a line is a stable snapshot.

enum PayrollStatus {
  draft
  approved
  paid
  void
}

enum PayRole {
  driver
  helper
}

model PayrollRun {
  id          String        @id @default(cuid())
  number      String        @unique // PAY-YYYY-NNNN
  periodFrom  DateTime      @db.Date
  periodTo    DateTime      @db.Date
  status      PayrollStatus @default(draft)
  total       Decimal       @db.Decimal(12, 2)
  workerCount Int           @default(0)
  notes       String?
  paidAt      DateTime?
  lines       PayrollLine[]
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
}

model PayrollLine {
  id         String     @id @default(cuid())
  run        PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId      String
  tripId     String
  workerId   String
  workerName String
  role       PayRole
  date       DateTime   @db.Date
  truckCode  String
  amount     Decimal    @db.Decimal(12, 2)

  @@index([runId])
  @@index([tripId])
  @@index([workerId])
}

// ---------- Costs / P&L ----------
// Per-truck "other" costs (maintenance, tolls, etc.). Fuel + driver/helper pay are
// NOT here — they live on logs/trips; the P&L report pulls them from there. ADR 0006.

enum CostCategory {
  maintenance
  toll
  insurance
  tax
  repair
  other
}

model TruckCost {
  id          String       @id @default(cuid())
  truck       Truck        @relation(fields: [truckId], references: [id])
  truckId     String
  date        DateTime     @db.Date
  category    CostCategory
  amount      Decimal      @db.Decimal(12, 2)
  note        String?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([truckId, date])
  @@index([date])
}

// ---------- Treasury ----------
// Bank/cash accounts + a categorized single-entry cash ledger (ADR 0007).
// Replaces Movimientos / Cash flow / Balance.

enum AccountKind {
  bank
  cash
}

enum TxDirection {
  inflow
  outflow
}

enum TxCategory {
  client_payment
  investment
  loan
  fuel
  salary
  maintenance
  toll
  insurance
  tax
  general
  transfer
  other
}

model BankAccount {
  id             String        @id @default(cuid())
  name           String
  kind           AccountKind   @default(bank)
  openingBalance Decimal       @default(0) @db.Decimal(14, 2)
  status         UserStatus    @default(active)
  transactions   Transaction[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Transaction {
  id          String      @id @default(cuid())
  account     BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId   String
  date        DateTime    @db.Date
  direction   TxDirection
  amount      Decimal     @db.Decimal(14, 2) // always positive; direction signs it
  category    TxCategory
  description String
  truckId     String? // optional cost/revenue allocation (plain ref)
  note        String?
  createdById String?
  createdAt   DateTime    @default(now())

  @@index([accountId, date])
  @@index([date])
}
