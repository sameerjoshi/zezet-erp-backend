# Copy to .env and adjust. Never commit the real .env.
NODE_ENV=development
PORT=3001

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL="postgresql://zezet:zezet@localhost:5432/zezet?schema=public"

# Redis (refresh tokens, cache)
REDIS_URL="redis://localhost:6379"

# Auth — generate strong values for real environments
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900"        # seconds (15m)
JWT_REFRESH_TTL="1209600"   # seconds (14d)

# CORS — frontend origin
CORS_ORIGIN="http://localhost:3000"
