# Copy to .env and adjust. Never commit the real .env.
NODE_ENV=development
PORT=3001

# PostgreSQL (matches docker-compose.yml — host port 5434 to avoid local clashes)
DATABASE_URL="postgresql://zezet:zezet@localhost:5434/zezet?schema=public"

# Redis (refresh tokens, cache — host port 6381 to avoid local clashes)
REDIS_URL="redis://localhost:6381"

# Auth — generate strong values for real environments
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900"        # seconds (15m)
JWT_REFRESH_TTL="1209600"   # seconds (14d)

# CORS — frontend origin
CORS_ORIGIN="http://localhost:3000"

# Seed — dev admin password used by `pnpm db:seed` (override in real environments)
SEED_ADMIN_PASSWORD="admin123"
